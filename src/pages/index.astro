---
import MainLayout from '../layouts/Main.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Link from '../components/Link.astro';
import ServiceCarousel from '../components/ServiceCarousel.astro';

const services = [
    {
        title: 'Elevated Water Storage & Gravity Irrigation',
        description: 'Vertically mounted water tanks are supported by ground-anchored tripod structures, allowing stored rainwater to be naturally pressurized and distributed through a gravity-fed irrigation network across the greenhouse—eliminating the need for pumps or external power.',
        gradient: 'blue' as const,
        icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z'
    },
    {
        title: 'Integrated Environmental Design',
        description: 'A PVC lattice framework supports airflow systems, suspended growing zones, and a photosynthetic enclosure, forming a fully coordinated environmental structure.',
        gradient: 'purple' as const,
        icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'
    },
    {
        title: 'Sustainable Water Systems',
        description: 'Gravity-driven irrigation and rainwater collection eliminate pump dependence, creating an efficient closed-loop water management system.',
        gradient: 'green' as const,
        icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'
    }
];
---

<MainLayout title="Home">
    <!-- Hero -->
    <section class="relative bg-linear-to-br from-indigo-600 via-purple-600 to-indigo-800 text-white py-18 md:py-26 overflow-hidden">
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-purple-500 rounded-full opacity-20 blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-16 -left-16 w-72 h-72 bg-indigo-400 rounded-full opacity-20 blur-3xl pointer-events-none"></div>

        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h1 class="text-4xl md:text-6xl font-bold mb-6">
                    Rethinking Sustainability Through Engineering
                </h1>
                <p class="text-xl md:text-2xl mb-8 text-indigo-100 max-w-3xl mx-auto">
                    A fully integrated greenhouse system designed to merge efficient water management, gravity-fed irrigation, and scalable agricultural infrastructure into one unified solution for community-based food production.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <Link href="/projects" class="bg-white text-indigo-600 px-8 py-3 rounded-lg font-semibold hover:bg-indigo-50 active:scale-95 transition-all duration-150 relative z-10">
                        System
                    </Link>
                    <Link href="/contact" class="bg-white/10 border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-indigo-600 active:scale-95 transition-all duration-150 backdrop-blur-sm relative z-10">
                        Contact
                    </Link>
                </div>
            </div>
        </div>

        <div class="absolute bottom-0 left-0 right-0">
            <svg viewBox="0 0 1435 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="#030712"/>
            </svg>
        </div>
    </section>

    <!-- What We Do -->
    <section class="py-20 bg-gray-950">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 text-white">What We Do</h2>
            <p class="text-gray-400 text-center max-w-2xl mx-auto mb-12">
                We design integrated systems that combine renewable energy, environmental engineering, and sustainability to create real-world, student-driven solutions.
            </p>
            <ServiceCarousel services={services} />
        </div>
    </section>

    <!-- Features -->
    <section class="py-16 bg-gray-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Features</h2>
                <p class="text-gray-400 text-lg">
                    Explore our work in sustainable system design, renewable energy integration, and applied environmental engineering.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <ProjectCard
                    title="Community-Scale Greenhouse System"
                    description="A cost-effective, scalable greenhouse designed for local food production, combining efficient water storage, gravity-based irrigation, and simple structural design to support food pantry supply chains."
                    gradient="blue"
                    icon="lightbulb"
                />
                <ProjectCard
                    title="Gravity Irrigation System"
                    description="An elevated, pump-free irrigation network using gravitational potential energy for efficient water distribution."
                    gradient="purple"
                    icon="lightning"
                />
                <ProjectCard
                    title="Closed-Loop Sustainability Model"
                    description="A system integrating rainwater capture, energy storage, and environmental monitoring into one cohesive architecture."
                    gradient="green"
                    icon="robot"
                />
            </div>

            <div class="text-center mt-12">
                <Link href="/projects" class="inline-block bg-indigo-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-indigo-700 active:scale-95 transition-all duration-150">
                    View The Full Build
                </Link>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="relative bg-linear-to-br from-indigo-600 via-purple-600 to-indigo-800 text-white py-20 overflow-hidden">
        <div class="absolute -top-20 -right-20 w-80 h-80 bg-purple-400 rounded-full opacity-20 blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-indigo-400 rounded-full opacity-20 blur-3xl pointer-events-none"></div>

        <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-3xl md:text-4xl font-bold mb-4">New here?</h2>
            <p class="text-xl mb-8 text-indigo-100">
                Learn how our greenhouse project is redefining sustainability through engineering, innovation, and real-world application.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <Link href="/about" class="inline-block bg-white text-indigo-700 px-8 py-3 rounded-lg font-bold hover:bg-indigo-50 active:scale-95 transition-all duration-150 shadow-lg">
                    About Us
                </Link>
                <Link href="/contact" class="inline-block bg-white/10 text-white px-8 py-3 rounded-lg font-bold border border-white/30 hover:bg-white/20 active:scale-95 transition-all duration-150 backdrop-blur-sm">
                    Get in Touch →
                </Link>
            </div>
        </div>
    </section>
</MainLayout>
